@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_NewLayout1.cshtml";
}

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
	<link href="~/lib/bootstrap/dist/css/indexnew.css" rel="stylesheet" />

</head>
<style>



</style>
<body>
    <div class="db-root">

        <div class="db-header">
            <div class="db-eyebrow">-------------</div>
            <div class="db-title">___________</div>
            
            <div class="db-divider"></div>
        </div>

        <div class="db-grid">

            <a class="db-card card-courses" href="@Url.Action("Coursepage", "Course")">
                <div class="card-icon-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                    </svg>
                </div>
                <div class="card-label">Module 01</div>
                <div class="card-title">Courses</div>
                <div class="card-desc">View and manage all courses in the system</div>
                <div class="card-accent"></div>
                <div class="card-arrow">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2.5 9.5l7-7M3 2.5h6.5V9" />
                    </svg>
                </div>
            </a>

            <a class="db-card card-depts" href="@Url.Action("DepartmentPage", "Department")">
                <div class="card-icon-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="7" height="14" />
                        <rect x="9" y="3" width="6" height="18" />
                        <rect x="15" y="10" width="7" height="11" />
                    </svg>
                </div>
                <div class="card-label">Module 02</div>
                <div class="card-title">Departments</div>
                <div class="card-desc">View and manage all departments across the institution</div>
                <div class="card-accent"></div>
                <div class="card-arrow">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2.5 9.5l7-7M3 2.5h6.5V9" />
                    </svg>
                </div>
            </a>

            <a class="db-card card-enroll" href="@Url.Action("EnrollmentPage", "Enrollment")">
                <div class="card-icon-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </div>
                <div class="card-label">Module 03</div>
                <div class="card-title">Enrollments</div>
                <div class="card-desc">View and manage all student enrollments and records</div>
                <div class="card-accent"></div>
                <div class="card-arrow">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2.5 9.5l7-7M3 2.5h6.5V9" />
                    </svg>
                </div>
            </a>

        </div>

        <div class="db-footer">
            <div class="db-footer-text">Academic Management System</div>
            <div class="db-status">
                <div class="db-status-dot"></div>
                All systems operational
            </div>
        </div>

    </div>

	
</body>

<script type="module"
		src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>


<script>
	function hideSidebar() {
		console.log("helllo")
		const sidebar = document.querySelector('nav');
		const menu = document.getElementById('menu');
		menu.style.display = 'flex';
		sidebar.style.display = 'none';
	}
	function showSidebar(){
		const sidebar = document.querySelector('nav');
		const menu = document.getElementById('menu');
		menu.style.display = 'none';
		sidebar.style.display = 'flex';
	}


	// slider script

	let next = document.querySelector('.next');
	let prev = document.querySelector('.prev');

	

	next.addEventListener('click', function () {
		let items = document.querySelectorAll('.item');
		document.querySelector('.slide').appendChild(items[0]);

		
	});
	
	prev.addEventListener('click', function () {
		let items = document.querySelectorAll('.item');
		document.querySelector('.slide').prepend(items[items.length - 1])

		
	});


</script>