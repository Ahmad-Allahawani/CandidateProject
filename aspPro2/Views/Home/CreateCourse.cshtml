
@model aspPro2.Models.Course
@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_NewLayout1.cshtml";
}
<head>
	<link href="~/lib/bootstrap/dist/css/CreateStyle.css" rel="stylesheet" />
</head>


<div class="form-root">

    <div class="form-header">
        <div class="form-eyebrow">Courses</div>
        <h1>___________________</h1>
    </div>

    <div class="form-card">
        <form asp-action="CreateCourse" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Title">Course Title</label>
                <input asp-for="Title" placeholder="e.g. Data Structures" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="DepartmentId">Department</label>
                <div class="select-wrap">
                    <select asp-for="DepartmentId" asp-items="ViewBag.Departments">
                        <option value="">-- Select a Department --</option>
                    </select>
                </div>
                <span asp-validation-for="DepartmentId" class="field-error"></span>
            </div>

            <div class="form-divider"></div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Create Course</button>
                <a class="btn-cancel" href="@Url.Action("Index", "Home")">Cancel</a>
            </div>

        </form>
    </div>

</div>