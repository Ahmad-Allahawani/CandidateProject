@model aspPro2.Models.Enrollment
@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_NewLayout1.cshtml";
}
<head>
    <link href="~/lib/bootstrap/dist/css/CreateStyle.css" rel="stylesheet" />
</head>


<div class="form-root">

    <div class="form-header">
        <div class="form-eyebrow">Enrollment</div>
        <h1>___________________</h1>
    </div>

    <div class="form-card">
        <form asp-action="CreateEnrollment" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="UserId">User</label>
                <div class="select-wrap">
                    <select asp-for="UserId" asp-items="ViewBag.User">
                        <option value="">-- Select a user --</option>
                    </select>
                </div>
                <span asp-validation-for="UserId" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="CourseId">Course</label>
                <div class="select-wrap">
                    <select asp-for="CourseId" asp-items="ViewBag.Course">
                        <option value="">-- Select a Course --</option>
                    </select>
                </div>
                <span asp-validation-for="CourseId" class="field-error"></span>
            </div>

            

            <div class="form-divider"></div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Create Enrollment</button>
                <a class="btn-cancel" href="@Url.Action("Index", "Home")">Cancel</a>
            </div>

        </form>
    </div>

</div>