@model List<aspPro2.Models.Enrollment>
@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_NewLayout1.cshtml";
}
<head>
    <link href="~/lib/bootstrap/dist/css/CRUDStyle.css" rel="stylesheet" />
</head>

<div class="crud-root">

    <div class="crud-header">
        <div class="crud-header-left">
            <div class="crud-eyebrow">Academic Management</div>
            <h1>________________</h1>
        </div>

    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>UserId</th>
                    <th>CourseId</th>
                    <th>EnrollmentDate</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var enroll in Model)
                {
                    <tr>
                        <td class="td-id">#@enroll.Id</td>
                        <td class="td-title">@enroll.UserId</td>
                        <td class="td-title">@enroll.CourseId</td>
                        <td class="td-title">@enroll.EnrollmentDate</td>
                       
                        <td>
                            <div class="actions-cell">
                                <button class="edit-btn"
                                        onclick="location.href='@Url.Action("EditEnrollment", "Home", new { id = enroll.Id })'">
                                    Edit
                                </button>
                                <form asp-action="DeleteEnrollment" asp-controller="Home" method="post">
                                    <input type="hidden" name="id" value="@enroll.Id" />
                                    <button type="submit" class="delete-btn">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="crud-footer">
        <a class="btn-add" href="@Url.Action("CreateEnrollment", "Home")">
            <span class="btn-add-icon">+</span>
            Add New Enrollment
        </a>
        <span class="crud-footer-text">@Model.Count() Enrollment(s) total</span>
        <a class="back-link" href="@Url.Action("Index", "Home")">
            ← Back to Dashboard
        </a>
    </div>

</div>