@model aspPro2.Models.Department
@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_NewLayout1.cshtml";
}
<head>
    <link href="~/lib/bootstrap/dist/css/CreateStyle.css" rel="stylesheet" />
</head>


<div class="form-root">

    <div class="form-header">
        <div class="form-eyebrow">Department</div>
        <h1>___________________</h1>
    </div>

    <div class="form-card">
        <form asp-action="CreateDepartment" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Name">Department Name</label>
                <input asp-for="Name" placeholder="e.g. Computer science " />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            @* <div class="form-group">
                <label asp-for="DepartmentId">Department</label>
                <div class="select-wrap">
                    <select asp-for="DepartmentId" asp-items="ViewBag.Departments">
                        <option value="">-- Select a Department --</option>
                    </select>
                </div>
                <span asp-validation-for="DepartmentId" class="field-error"></span>
            </div> *@

            <div class="form-divider"></div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Create Department</button>
                <a class="btn-cancel" href="@Url.Action("DepartmentPage", "Home")">Cancel</a>
            </div>

        </form>
    </div>

</div>