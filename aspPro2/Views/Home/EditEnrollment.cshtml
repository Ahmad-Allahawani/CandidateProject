<!-- Edit.cshtml -->
@model aspPro2.Models.Enrollment

@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_NewLayout1.cshtml";
}
<head>
    <link href="~/lib/bootstrap/dist/css/editstyle.css" rel="stylesheet" />
</head>

<div class="form-root">

    <div class="form-header">
        <div class="form-eyebrow">Enrollments</div>
        <h1>__________________</h1>
    </div>

    <div class="form-card">
        
        <form asp-action="EditEnrollment" method="post">
            <div class="form-group">
                <label asp-for="Id">Enrollment ID</label>
                <input asp-for="Id" placeholder="e.g. 1234 " />
                <span asp-validation-for="Id" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="EnrollmentDate">Enrollment Date</label>
                <input asp-for="EnrollmentDate" placeholder="e.g. 4/4/2026 1:14:58 AM " />
                <span asp-validation-for="EnrollmentDate" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserId">User</label>
                <div class="select-wrap">
                    <select asp-for="UserId" asp-items="ViewBag.User">
                        <option value="">-- Select a user --</option>
                    </select>
                </div>
                <span asp-validation-for="UserId" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="CourseId">Course</label>
                <div class="select-wrap">
                    <select asp-for="CourseId" asp-items="ViewBag.Course">
                        <option value="">-- Select a Course --</option>
                    </select>
                </div>
                <span asp-validation-for="CourseId" class="field-error"></span>
            </div>

           

            <div class="form-divider"></div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Save Changes</button>
                <a class="btn-cancel" href="@Url.Action("Index", "Home")">Cancel</a>
            </div>

        </form>
    </div>

</div>