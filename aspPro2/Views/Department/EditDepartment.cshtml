<!-- Edit.cshtml -->
@model aspPro2.Models.Department

@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_NewLayout1.cshtml";
}
<head>
    <link href="~/lib/bootstrap/dist/css/editstyle.css" rel="stylesheet" />
</head>

<div class="form-root">

    <div class="form-header">
        <div class="form-eyebrow">Departments</div>
        <h1>__________________</h1>
    </div>

    <div class="form-card">
        <form asp-action="EditDepartment" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label>Course ID</label>
                <div class="id-badge">#@Model.Id</div>
            </div>

            <div class="form-group">
                <label asp-for="Name">Course Title</label>
                <input asp-for="Name" placeholder="e.g. Data Structures" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            

            <div class="form-divider"></div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Save Changes</button>
                <a class="btn-cancel" href="@Url.Action("Index", "Home")">Cancel</a>
            </div>

        </form>
    </div>

</div>